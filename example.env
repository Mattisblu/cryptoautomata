# Example .env for CryptoAutomata

# Local PostgreSQL database
DATABASE_URL=postgres://youruser:yourpassword@localhost:5432/cryptobot

# Local LLM (Ollama or qwen2.5:7b)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3-7b

# Optional Ollama tuning (reduce memory & improve latency):
# - OLLAMA_NUM_CTX: reduce model context window (smaller -> less RAM)
# - OLLAMA_GPU_LAYERS: number of layers to offload to GPU (if GPU available)
# - OLLAMA_KEEP_ALIVE: how long Ollama worker stays warm (e.g., 60s)
# - OLLAMA_KV_CACHE_TYPE: key-value context cache type (e.g., q8_0)
# Example safer defaults you can try locally:
OLLAMA_NUM_CTX=2048
OLLAMA_GPU_LAYERS=32
OLLAMA_KEEP_ALIVE=60s
OLLAMA_KV_CACHE_TYPE=q8_0

# Server ports
FRONTEND_PORT=3000
BACKEND_PORT=4000

# Other config (customize as needed)
NODE_ENV=development
LOG_LEVEL=info

# Exchange API keys (if needed)
COINSTORE_API_KEY=
BYDFI_API_KEY=
BITUNIX_API_KEY=
TOOBIT_API_KEY=

# Add any other secrets or config below
