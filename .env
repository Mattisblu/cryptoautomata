# Ollama configuration
# URL for local Ollama API
OLLAMA_URL=http://localhost:11434
# Ollama model to use (tune to an available model that fits memory)
OLLAMA_MODEL=glm-4.7-flash
# Reduce default LLM context window (num_ctx) to save memory
OLLAMA_NUM_CTX=2048
# Offload layer count to GPU (number of layers to place on GPU)
OLLAMA_GPU_LAYERS=32
# Keep Ollama worker alive shorter to free resources (supports values like 60s)
OLLAMA_KEEP_ALIVE=60s
# KV context cache type (q8_0 recommended for lower memory usage)
OLLAMA_KV_CACHE_TYPE=q8_0
FRONTEND_PORT=3000
LOG_LEVEL=info
BACKEND_PORT=5000
DATABASE_URL=postgres://postgres:crypto1@localhost:5344/postgres
PORT=5000
NODE_ENV=development
LOG_LEVEL=info